# --- API Keys ---
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
UNIPILE_API_KEY=your_unipile_api_key_here

# --- Environment Settings ---
ALLOWED_ORIGINS=*
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4-turbo-preview
DEBUG_LOG_PATH=/tmp/debug_sync.log

# --- ZoomInfo Contact Enrichment ---
ZOOMINFO_ENRICH_URL=https://api.zoominfo.com/enrich/contact
ZOOMINFO_BEARER_TOKEN=
ZOOMINFO_CLIENT_ID=

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=postgres
# CLOUDSQL_CONNECTION_NAME=project:region:instance (optional)

# --- JobDiva ---
JOBDIVA_API_URL=https://api.jobdiva.com
JOBDIVA_CLIENT_ID=your_jobdiva_client_id_here
JOBDIVA_USERNAME=your_jobdiva_username_here
JOBDIVA_PASSWORD=your_jobdiva_password_here

# --- Unipile ---
UNIPILE_DSN=api1.unipile.com
UNIPILE_ACCOUNT_ID=your_unipile_account_id_here

# --- UDF IDs (Optional, defaults provided) ---
# JOBDIVA_AI_JD_UDF_ID=230
# JOBDIVA_JOB_NOTES_UDF_ID=231

# --- Encryption ---
ENCRYPTION_KEY=your_encryption_key_here
ENCRYPTION_SALT=your_encryption_salt_here

# --- SMTP (used by Tira's "Report a bug" form) ---
# Leave blank to disable outbound bug-report emails; the /tira/bug-report
# endpoint will still accept submissions and log them server-side.
SMTP_HOST=
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
